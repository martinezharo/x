---
import people from "../data.js";

const FOLLOWING = "bg-transparent text-zinc-200 hover:bg-red-900/15 before:content-['Following'] hover:before:content-['Unfollow']"
const FOLLOW = "bg-zinc-200 text-gray-900 hover:bg-white  before:content-['Follow']"
---

<section id="follow-section" class="w-full">
	<h2 class="text-2xl font-bold ml-4 mb-3">Who to follow</h2>
	<div id="follow-container">
		{
			people.map((person) => (
				<div
					class="flex items-center justify-between
				px-5 py-2 border-b border-white/10
				first:border-t first:border-white/10"
				>
					<div class="flex items-center gap-2">
						<img
							src={person.img}
							class="w-10 aspect-square rounded-full object-cover"
						/>
						<span class="names-container">
							<div class="font-bold text-base">{person.name}</div>
							<div class="font-thin text-sm">
								@{person.username}
							</div>
						</span>
					</div>
					<button
						class={`follow min-w-[85px] px-3 py-1 rounded-full
					text-xs font-bold ease-in-out duration-150
					border border-zinc-200/20
					${person.isFollowing ? FOLLOWING : FOLLOW}
					`}
					></button>
				</div>
			))
		}
	</div>
</section>

